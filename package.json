{
  "name": "hot-updater-server",
  "version": "1.0.0",
  "description": "Self-hosted Hot Updater API server - Supabase Storage + Prisma SQLite",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "hot-updater db generate src/hotUpdater.ts --yes",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@hot-updater/server": "latest",
    "@hot-updater/standalone": "latest",
    "@hot-updater/supabase": "latest",
    "@prisma/client": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "hot-updater": "latest",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
