# ================================
# Hot Updater - Supabase Storage
# ================================

# Supabase project URL (Project Settings → API)
HOT_UPDATER_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (Project Settings → API)
HOT_UPDATER_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Storage bucket name (create in Storage section)
HOT_UPDATER_SUPABASE_BUCKET_NAME=hot-updater-bundles

# ================================
# Server Configuration
# ================================

PORT=3000
SERVER_BASE_URL=http://localhost:3000

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HOT_UPDATER_API_KEY=your-super-secret-api-key-change-me

# ================================
# Prisma SQLite Database
# ================================

# Path to SQLite file (relative to project root)
DATABASE_URL="file:./data/hot_updater.db"

# ================================
# Optional: CORS
# ================================
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
